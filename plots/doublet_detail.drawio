<mxfile host="app.diagrams.net">
  <diagram name="Doublet-Aware Contamination Estimation" id="doublet-detail">
    <mxGraphModel dx="1957" dy="1323" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1100" pageHeight="1680" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="2" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontStyle=1;fontSize=25;fontColor=#1A1A2E;" value="Doublet-Aware Contamination Estimation" vertex="1">
          <mxGeometry height="36" width="780" x="140" y="-43" as="geometry" />
        </mxCell>
        <mxCell id="3" parent="1" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#D6EAF8;strokeColor=#1F618D;strokeWidth=2;fontStyle=1;fontSize=25;verticalAlign=top;" value="&lt;b&gt;Input: Single Cell RNA Data&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;All-droplet count matrix, cell-only count matrix, and a cluster label for each cell&lt;/span&gt;" vertex="1">
          <mxGeometry height="115" width="677" x="193" y="23" as="geometry" />
        </mxCell>
        <mxCell id="4" parent="1" style="rounded=1;arcSize=6;whiteSpace=wrap;html=1;strokeWidth=2.5;fontStyle=1;fontSize=25;verticalAlign=top;fillColor=#EAF2FF;strokeColor=#2471A3;" value="&lt;b&gt;Step 1: Build the Ambient Soup Profile&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;Sum gene counts from empty droplets that contain no real cell.&lt;br&gt;Divide each gene total by the grand total to get its fraction in the ambient fluid.&lt;/span&gt;" vertex="1">
          <mxGeometry height="181" width="688" x="187.5" y="196" as="geometry" />
        </mxCell>
        <mxCell id="5" edge="1" parent="1" source="3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#2471A3;strokeWidth=2.5;endArrow=block;endFill=1;fontSize=25;" target="4" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="6" parent="1" style="rounded=1;arcSize=6;whiteSpace=wrap;html=1;strokeWidth=2.5;fontStyle=1;fontSize=25;verticalAlign=top;fillColor=#EAFAF1;strokeColor=#1E8449;" value="&lt;b&gt;Step 2: Score Each Cell for Doublet Likelihood&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;Create artificial doublets by adding together random pairs of real cell counts.&lt;br&gt;Project all real and artificial cells into PCA space and score each real cell by the fraction of its 20 nearest neighbors that are artificial doublets.&lt;/span&gt;" vertex="1">
          <mxGeometry height="196" width="693" x="185" y="448" as="geometry" />
        </mxCell>
        <mxCell id="7" edge="1" parent="1" source="4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#1E8449;strokeWidth=2.5;endArrow=block;endFill=1;fontSize=25;" target="6" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="8" parent="1" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#FEF9E7;strokeColor=#7D6608;strokeWidth=2;fontStyle=0;fontSize=25;verticalAlign=top;" value="&lt;b&gt;Settings used&lt;/b&gt;&lt;br&gt;Artificial doublets: equal to number of real cells&lt;br&gt;Top variable genes: 2000&lt;br&gt;PCA components: 30&lt;br&gt;Nearest neighbors: 20" vertex="1">
          <mxGeometry height="195" width="481" x="-359" y="448" as="geometry" />
        </mxCell>
        <mxCell id="9" edge="1" parent="1" source="6" style="edgeStyle=elbowEdgeStyle;elbow=vertical;rounded=1;strokeColor=#7D6608;strokeWidth=1.5;strokeDasharray=6 3;endArrow=open;endFill=0;fontSize=25;" target="8" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="10" parent="1" style="rounded=1;arcSize=6;whiteSpace=wrap;html=1;strokeWidth=2.5;fontStyle=1;fontSize=25;verticalAlign=top;fillColor=#F5EEF8;strokeColor=#6C3483;" value="&lt;b&gt;Step 3: Flag Cells as Doublets&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;Mark a cell as a doublet if its score is at least 0.25 and at least 1.5 times the expected random background.&lt;br&gt;Also require its total RNA count to be above 1.5 times the dataset median, since real doublets carry roughly twice the normal RNA amount.&lt;/span&gt;" vertex="1">
          <mxGeometry height="200" width="676" x="193" y="699" as="geometry" />
        </mxCell>
        <mxCell id="11" edge="1" parent="1" source="6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#6C3483;strokeWidth=2.5;endArrow=block;endFill=1;fontSize=25;" target="10" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="12" parent="1" style="rounded=1;arcSize=6;whiteSpace=wrap;html=1;strokeWidth=2.5;fontStyle=1;fontSize=25;verticalAlign=top;fillColor=#FEF5E7;strokeColor=#935116;" value="&lt;b&gt;Step 4: Estimate Contamination Using All Cells&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;Run the standard Bayesian contamination estimation using all cells and their original cluster labels.&lt;br&gt;Flagged doublets are included here so their inflated RNA counts do not distort the cluster-level evidence.&lt;/span&gt;" vertex="1">
          <mxGeometry height="196" width="668" x="196" y="983" as="geometry" />
        </mxCell>
        <mxCell id="13" edge="1" parent="1" source="10" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#935116;strokeWidth=2.5;endArrow=block;endFill=1;fontSize=25;" target="12" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="14" parent="1" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#FEF9E7;strokeColor=#7D6608;strokeWidth=2;fontStyle=0;fontSize=25;verticalAlign=top;" value="&lt;b&gt;Settings used&lt;/b&gt;&lt;br&gt;Specificity threshold: 1.0&lt;br&gt;Soup presence: top 10 percent&lt;br&gt;Prior contamination: 5 percent&lt;br&gt;Allowed range: 1 to 80 percent&lt;br&gt;Grid size: 1001 candidate values" vertex="1">
          <mxGeometry height="235" width="481" x="-354" y="968" as="geometry" />
        </mxCell>
        <mxCell id="15" edge="1" parent="1" source="12" style="edgeStyle=elbowEdgeStyle;elbow=vertical;rounded=1;strokeColor=#7D6608;strokeWidth=1.5;strokeDasharray=6 3;endArrow=open;endFill=0;fontSize=25;" target="14" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="16" parent="1" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#F4F6F7;strokeColor=#717D7E;strokeWidth=2;fontStyle=0;fontSize=25;verticalAlign=top;" value="&lt;b&gt;Why include doublets in the estimation?&lt;/b&gt;&lt;br&gt;Doublets carry about twice the normal RNA count. Excluding them before estimation causes the non-expressing test to pass for genes doublets genuinely express, which incorrectly inflates the contamination fraction for the whole dataset." vertex="1">
          <mxGeometry height="210" width="602" x="913" y="980.5" as="geometry" />
        </mxCell>
        <mxCell id="17" edge="1" parent="1" source="12" style="edgeStyle=elbowEdgeStyle;elbow=vertical;rounded=1;strokeColor=#717D7E;strokeWidth=1.5;strokeDasharray=6 3;endArrow=open;endFill=0;fontSize=25;" target="16" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="18" parent="1" style="rounded=1;arcSize=6;whiteSpace=wrap;html=1;strokeWidth=2.5;fontStyle=1;fontSize=25;verticalAlign=top;fillColor=#EBF5FB;strokeColor=#1A5276;" value="&lt;b&gt;Step 5: Replace Doublet Contamination Values&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;For each flagged doublet, replace its contamination estimate with the average value from its non-doublet cluster mates.&lt;br&gt;This gives every doublet a plausible contamination fraction without letting its mixed expression affect the result.&lt;/span&gt;" vertex="1">
          <mxGeometry height="196" width="662" x="199" y="1234" as="geometry" />
        </mxCell>
        <mxCell id="19" edge="1" parent="1" source="12" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#1A5276;strokeWidth=2.5;endArrow=block;endFill=1;fontSize=25;" target="18" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="20" parent="1" style="rounded=1;arcSize=6;whiteSpace=wrap;html=1;strokeWidth=2.5;fontStyle=1;fontSize=25;verticalAlign=top;fillColor=#E8F8F5;strokeColor=#1A7349;" value="&lt;b&gt;Step 6: Remove Contamination from Each Cell&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;Subtract expected ambient counts from each cell using its contamination fraction from Step 4 (or Step 5 for doublets) and the ambient profile from Step 1.&lt;br&gt;Any count that would go below zero is set to zero.&lt;/span&gt;" vertex="1">
          <mxGeometry height="196" width="659" x="199" y="1485" as="geometry" />
        </mxCell>
        <mxCell id="21" edge="1" parent="1" source="18" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#1A7349;strokeWidth=2.5;endArrow=block;endFill=1;fontSize=25;" target="20" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="22" parent="1" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#D5F5E3;strokeColor=#1E8449;strokeWidth=2;fontStyle=1;fontSize=25;verticalAlign=top;" value="&lt;b&gt;Output: Corrected Count Matrix&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;Cleaned count matrix with ambient RNA removed from every cell, plus a per-cell contamination fraction and doublet score.&lt;/span&gt;" vertex="1">
          <mxGeometry height="115" width="677" x="190" y="1726" as="geometry" />
        </mxCell>
        <mxCell id="23" edge="1" parent="1" source="20" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#1E8449;strokeWidth=2.5;endArrow=block;endFill=1;fontSize=25;" target="22" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
